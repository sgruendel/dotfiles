[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  lol = log --oneline --graph --all

# use delta, see https://github.com/dandavison/delta
#[core]
#  pager = delta
#[interactive]
#  diffFilter = delta --color-only
#[delta]
#    navigate = true  # use n and N to move between diff sections

# use hunk, see https://github.com/modem-dev/hunk
[core]
  pager = hunk pager

[column]
  ui = auto
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
[merge]
  conflictstyle = zdiff3
[push]
  default = simple
  autoSetupRemote = true
  followTags = true
[pull]
  rebase = true
[fetch]
  prune = true
  pruneTags = true
  all = true

[rerere]
  enabled = true
  autoupdate = true
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
